---
---
<section class="social" id="social">
  <div class="container">

    <div class="section-header">
      <div class="section-tag">♣ Premium · Social &amp; Community</div>
      <h2 class="section-title">Play Together. Compete. Connect.</h2>
      <p class="section-subtitle">
        Premium subscribers unlock a full social layer on top of every game —
        from in-game voice chat to Discord-powered friend invites.
      </p>
    </div>

    <!-- Feature rows -->
    <div class="sf-rows">

      <!-- Discord -->
      <div class="sf-row sf-row--alt">
        <div class="sf-row-visual discord-visual" aria-hidden="true">
          <div class="discord-card">
            <div class="dc-avatar">🎮</div>
            <div class="dc-info">
              <div class="dc-name">VanikarGames</div>
              <div class="dc-status"><span class="dc-dot"></span>Playing Spades · 3rd trick</div>
            </div>
          </div>
          <div class="discord-invite">
            <span class="di-icon">🎲</span>
            <div>
              <div class="di-name">Join Game</div>
              <div class="di-sub">Spades · Private Table #4421</div>
            </div>
            <button class="di-btn">Join</button>
          </div>
        </div>
        <div class="sf-row-copy">
          <div class="sf-row-badge premium-badge">Premium</div>
          <h3>Discord Integration</h3>
          <p>
            Link your Discord account and your game status automatically appears in your
            Discord profile. Send game invites directly to Discord friends, join servers
            dedicated to each card game, and get push notifications via Discord DM.
          </p>
          <ul class="sf-list">
            <li>🟣 Rich presence — live game status in your Discord profile</li>
            <li>📨 One-click game invites to Discord contacts</li>
            <li>🔔 Match alerts and friend activity via DM</li>
            <li>🗄️ Official community servers per game</li>
          </ul>
        </div>
      </div>

      <!-- Voice Chat -->
      <div class="sf-row">
        <div class="sf-row-copy">
          <div class="sf-row-badge premium-badge">Premium</div>
          <h3>In-Game Voice Chat</h3>
          <p>
            Talk strategy with your partner in a two-vs-two match, trash-talk your opponent
            across the table in Bluff, or stay silent and keep them guessing. Crystal-clear
            audio, push-to-talk or open-mic, with per-player volume controls.
          </p>
          <ul class="sf-list">
            <li>🎙️ Push-to-talk or open-mic mode</li>
            <li>🔇 Per-player mute &amp; volume controls</li>
            <li>🏠 Separate team channels in partnership games</li>
            <li>🔒 Private tables include private voice rooms</li>
          </ul>
        </div>
        <div class="sf-row-visual voice-visual" aria-hidden="true">
          <div class="voice-card">
            <div class="vc-header">
              <span class="vc-icon">🎙️</span>
              <span class="vc-title">Voice Chat · Spades Table</span>
              <span class="vc-live">● LIVE</span>
            </div>
            <div class="vc-players">
              <div class="vc-player vc-speaking">
                <span class="vc-avatar">👤</span>
                <span class="vc-name">You</span>
                <span class="vc-wave">〜〜〜</span>
              </div>
              <div class="vc-player">
                <span class="vc-avatar">👤</span>
                <span class="vc-name">Partner</span>
                <span class="vc-muted">🔇</span>
              </div>
              <div class="vc-player">
                <span class="vc-avatar">👤</span>
                <span class="vc-name">Opponent 1</span>
              </div>
              <div class="vc-player">
                <span class="vc-avatar">👤</span>
                <span class="vc-name">Opponent 2</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Leaderboards + Stats (side by side cards) -->
      <div class="sf-row sf-row--alt">
        <div class="sf-row-visual lb-visual" aria-hidden="true">
          <div class="lb-card">
            <div class="lb-header">🏆 Global · Spades</div>
            <ol class="lb-list">
              <li class="lb-item lb-gold">   <span>#1</span><span>CardShark99</span><span>2,840 pts</span></li>
              <li class="lb-item lb-silver"> <span>#2</span><span>AceOfSpades</span><span>2,715 pts</span></li>
              <li class="lb-item lb-bronze"> <span>#3</span><span>TrumpMaster</span><span>2,690 pts</span></li>
              <li class="lb-item">           <span>#4</span><span>DealerKing</span><span>2,601 pts</span></li>
              <li class="lb-item lb-you">    <span>#12</span><span>You</span><span>2,340 pts</span></li>
            </ol>
            <div class="lb-tabs">
              <button class="lb-tab lb-tab--active">Global</button>
              <button class="lb-tab">Regional</button>
              <button class="lb-tab">Friends</button>
            </div>
          </div>
        </div>
        <div class="sf-row-copy">
          <div class="sf-row-badge premium-badge">Premium</div>
          <h3>Leaderboards &amp; Personal Stats</h3>
          <p>
            Every game has its own ranking — see where you stand globally, regionally,
            and among friends. Your detailed stats dashboard tracks everything.
          </p>
          <ul class="sf-list">
            <li>🌍 Global, regional, and friends-only rankings per game</li>
            <li>📈 Win/loss ratio, longest win streak, average game duration</li>
            <li>📊 Favourite game, most-played opening, performance over time</li>
            <li>🏅 Seasonal rankings that reset monthly</li>
          </ul>
        </div>
      </div>

      <!-- Achievements -->
      <div class="sf-row">
        <div class="sf-row-copy">
          <div class="sf-row-badge premium-badge">Premium</div>
          <h3>Achievements &amp; Player Profile</h3>
          <p>
            Over 150 achievements across all games. Unlock badges that display on your
            public profile. Earn XP to level up your Vanikar rank — from Novice Dealer
            to Grand Master.
          </p>
          <ul class="sf-list">
            <li>🥇 150+ achievements spanning all 17 games</li>
            <li>🎖️ Profile badges visible to opponents and friends</li>
            <li>⭐ XP &amp; level system: Novice → Expert → Grand Master</li>
            <li>🔓 Exclusive avatar frames and card-back skins for high ranks</li>
          </ul>
        </div>
        <div class="sf-row-visual ach-visual" aria-hidden="true">
          <div class="ach-grid">
            <div class="ach-item ach-gold"   title="Grand Slammer">🎯</div>
            <div class="ach-item ach-gold"   title="Shoot the Moon">🌙</div>
            <div class="ach-item ach-silver" title="Nil Master">🃏</div>
            <div class="ach-item ach-silver" title="Club Champion">♣</div>
            <div class="ach-item ach-bronze" title="50-Win Streak">🔥</div>
            <div class="ach-item ach-bronze" title="Night Owl">🦉</div>
            <div class="ach-item ach-locked" title="??">🔒</div>
            <div class="ach-item ach-locked" title="??">🔒</div>
            <div class="ach-item ach-locked" title="??">🔒</div>
          </div>
          <div class="ach-level">
            <span class="level-badge">Lv 24 · Expert</span>
            <div class="level-bar"><div class="level-fill" style="width:62%"></div></div>
            <span class="level-xp">6,200 / 10,000 XP</span>
          </div>
        </div>
      </div>

    </div><!-- /sf-rows -->

    <!-- Friends -->
    <div class="friends-banner">
      <div class="fb-inner">
        <span class="fb-icon">👥</span>
        <div>
          <strong>Friend System</strong>
          <span>Add friends by username, see who's online, and invite them to any table instantly.</span>
        </div>
        <a href="/pricing" class="btn btn-primary fb-cta">Get Premium</a>
      </div>
    </div>

  </div>
</section>

<style>
  .social { background: var(--bg-primary); padding: 5rem 0; }

  /* Feature rows */
  .sf-rows { display: flex; flex-direction: column; gap: 4rem; margin-bottom: 3rem; }

  .sf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .sf-row--alt .sf-row-visual { order: -1; }

  .sf-row-badge { display: inline-block; margin-bottom: .6rem; }
  .premium-badge {
    background: var(--gold-subtle); color: var(--gold); border: 1px solid var(--gold-border);
    border-radius: var(--radius-full); padding: .2rem .65rem;
    font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em;
  }
  .sf-row-copy h3 { font-size: 1.5rem; margin-bottom: .75rem; font-family: 'Cinzel',serif; }
  .sf-row-copy p  { font-size: .95rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }
  .sf-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .5rem; }
  .sf-list li { font-size: .875rem; color: var(--text-secondary); }

  /* Visual panels */
  .sf-row-visual {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-xl); padding: 1.5rem; overflow: hidden;
  }

  /* Discord visual */
  .discord-visual { background: #1e1f22; border-color: #5865F2; }
  .discord-card { display: flex; align-items: center; gap: .85rem; background: #2b2d31; border-radius: 8px; padding: .85rem 1rem; margin-bottom: .75rem; }
  .dc-avatar { font-size: 1.6rem; background: #5865F2; border-radius: 50%; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .dc-name   { font-size: .9rem; font-weight: 700; color: #fff; margin-bottom: .15rem; }
  .dc-status { font-size: .78rem; color: #b5bac1; display: flex; align-items: center; gap: .3rem; }
  .dc-dot    { width: 8px; height: 8px; border-radius: 50%; background: #23a559; flex-shrink: 0; }
  .discord-invite { display: flex; align-items: center; gap: .75rem; background: #2b2d31; border: 1px dashed #5865F2; border-radius: 8px; padding: .85rem 1rem; }
  .di-icon   { font-size: 1.4rem; }
  .di-name   { font-size: .85rem; font-weight: 600; color: #fff; }
  .di-sub    { font-size: .72rem; color: #b5bac1; }
  .di-btn    { margin-left: auto; background: #5865F2; color: #fff; border: none; border-radius: 4px; padding: .35rem .85rem; font-size: .8rem; font-weight: 700; cursor: pointer; flex-shrink: 0; }

  /* Voice visual */
  .voice-visual { background: #0f1a0f; }
  .vc-header { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; }
  .vc-icon   { font-size: 1.2rem; }
  .vc-title  { font-size: .85rem; font-weight: 700; color: var(--text-primary); flex: 1; }
  .vc-live   { font-size: .68rem; font-weight: 700; color: #e07070; background: rgba(224,112,112,.12); border-radius: var(--radius-full); padding: .15rem .5rem; }
  .vc-players { display: flex; flex-direction: column; gap: .4rem; }
  .vc-player  { display: flex; align-items: center; gap: .6rem; background: var(--bg-card); border-radius: var(--radius-sm); padding: .45rem .7rem; font-size: .82rem; }
  .vc-avatar  { font-size: .95rem; }
  .vc-name    { flex: 1; color: var(--text-secondary); }
  .vc-speaking{ border-left: 2px solid #7acc7a; }
  .vc-wave    { color: #7acc7a; font-size: .75rem; letter-spacing: -.05em; }
  .vc-muted   { font-size: .85rem; opacity: .5; }

  /* Leaderboard visual */
  .lb-visual  { padding: 0; overflow: hidden; }
  .lb-card    { padding: 1.25rem; }
  .lb-header  { font-size: .85rem; font-weight: 700; color: var(--gold); margin-bottom: .75rem; }
  .lb-list    { list-style: none; padding: 0; margin: 0 0 .75rem; display: flex; flex-direction: column; gap: .3rem; }
  .lb-item    { display: flex; gap: .75rem; font-size: .82rem; color: var(--text-secondary); background: var(--bg-feature); border-radius: var(--radius-sm); padding: .4rem .7rem; align-items: center; }
  .lb-item span:first-child { color: var(--text-dim); width: 26px; flex-shrink: 0; }
  .lb-item span:last-child  { margin-left: auto; color: var(--gold-light); font-weight: 600; }
  .lb-gold   .lb-item, .lb-gold   { background: rgba(201,162,39,.1) !important; }
  .lb-gold   span:first-child { color: var(--gold) !important; font-weight: 700; }
  .lb-silver span:first-child { color: #b0c0cc !important; font-weight: 700; }
  .lb-bronze span:first-child { color: #cd7f32 !important; font-weight: 700; }
  .lb-you    { border: 1px solid var(--gold-border) !important; }
  .lb-you span:first-child { color: var(--gold) !important; }
  .lb-tabs { display: flex; gap: .3rem; }
  .lb-tab { padding: .3rem .8rem; border-radius: var(--radius-full); font-size: .72rem; font-weight: 600; background: transparent; border: 1px solid var(--border); color: var(--text-muted); cursor: pointer; }
  .lb-tab--active { background: var(--gold-subtle); border-color: var(--gold-border); color: var(--gold); }

  /* Achievements visual */
  .ach-visual { display: flex; flex-direction: column; gap: 1.25rem; }
  .ach-grid   { display: grid; grid-template-columns: repeat(3,1fr); gap: .75rem; }
  .ach-item   { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; border-radius: var(--radius-md); border: 2px solid transparent; }
  .ach-gold   { background: rgba(201,162,39,.15); border-color: var(--gold-border); }
  .ach-silver { background: rgba(176,192,204,.1);  border-color: rgba(176,192,204,.3); }
  .ach-bronze { background: rgba(205,127,50,.1);   border-color: rgba(205,127,50,.3); }
  .ach-locked { background: var(--bg-secondary); border-color: var(--border); opacity: .4; }
  .ach-level  { text-align: center; }
  .level-badge { font-size: .78rem; font-weight: 700; color: var(--gold-light); display: block; margin-bottom: .4rem; }
  .level-bar   { height: 6px; background: var(--bg-secondary); border-radius: var(--radius-full); overflow: hidden; margin-bottom: .3rem; }
  .level-fill  { height: 100%; background: linear-gradient(90deg,var(--gold-dark),var(--gold)); border-radius: var(--radius-full); }
  .level-xp    { font-size: .72rem; color: var(--text-dim); }

  /* Friends banner */
  .friends-banner { background: linear-gradient(135deg,var(--bg-card),rgba(201,162,39,.06)); border: 1px solid var(--gold-border); border-radius: var(--radius-xl); padding: 1.5rem 2rem; }
  .fb-inner { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .fb-icon  { font-size: 2rem; flex-shrink: 0; }
  .fb-inner div { flex: 1; min-width: 200px; }
  .fb-inner strong { display: block; font-size: .95rem; color: var(--text-primary); margin-bottom: .2rem; font-family: 'Inter',sans-serif; font-weight: 700; }
  .fb-inner span { font-size: .85rem; color: var(--text-muted); }
  .fb-cta { flex-shrink: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .sf-row { grid-template-columns: 1fr; gap: 2rem; }
    .sf-row--alt .sf-row-visual { order: 0; }
  }
</style>
