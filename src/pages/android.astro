---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Card Games by Vanikar — Coming Soon on Android"
  description="The Vanikar Card Games app is coming soon to Google Play. 33 card games, online multiplayer, voice chat, leaderboards, Discord integration and more."
>
  <div class="store-page store-page--android">

    <div class="store-hero">
      <div class="container">
        <a href="/" class="back-link">← Back to Vanikar Games</a>

        <div class="store-hero-inner">
          <div class="platform-badge android-badge">
            <span class="platform-icon">▶</span>
            <span>Google Play</span>
          </div>

          <h1 class="store-title">Coming Soon<br/>on <span class="platform-accent">Android</span></h1>
          <p class="store-subtitle">
            33 classic card games in your pocket — online multiplayer, smart AI opponents,
            voice chat, leaderboards, Discord integration, and more.
          </p>

          <div class="store-meta">
            <span class="meta-chip">📱 Android phones &amp; tablets</span>
            <span class="meta-chip">🤖 Android 9+</span>
            <span class="meta-chip">🆓 Free to download</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Notify -->
    <section class="notify-section">
      <div class="container notify-inner">
        <div class="notify-copy">
          <h2>Get notified at launch</h2>
          <p>Be the first to know when the app hits Google Play. One email, no spam.</p>
        </div>
        <form class="notify-form" onsubmit="handleSubmit(event)">
          <input type="email" placeholder="your@email.com" required class="notify-input" aria-label="Email address" />
          <button type="submit" class="btn btn-primary notify-btn">Notify Me</button>
        </form>
        <p class="notify-fine" id="notify-confirm" hidden>✓ You're on the list — we'll email you at launch!</p>
      </div>
    </section>

    <!-- Features -->
    <section class="store-features">
      <div class="container">
        <h2 class="section-title" style="text-align:center;margin-bottom:2.5rem">What's inside</h2>
        <div class="sf-grid">
          <div class="sf-card">
            <span class="sf-icon">🃏</span>
            <h3>33 Card Games</h3>
            <p>From High Card to Skat — with 16 more games coming soon for subscribers first.</p>
          </div>
          <div class="sf-card">
            <span class="sf-icon">🌐</span>
            <h3>Online Multiplayer</h3>
            <p>Play live against real opponents from around the world at any time.</p>
          </div>
          <div class="sf-card">
            <span class="sf-icon">🤖</span>
            <h3>AI Practice</h3>
            <p>Sharpen your skills offline against responsive AI at multiple difficulty levels.</p>
          </div>
          <div class="sf-card">
            <span class="sf-icon">🎙️</span>
            <h3>Voice Chat</h3>
            <p>Talk to your teammates and opponents during live games — premium feature.</p>
          </div>
          <div class="sf-card">
            <span class="sf-icon">🏆</span>
            <h3>Leaderboards</h3>
            <p>Compete in global and regional rankings for every game.</p>
          </div>
          <div class="sf-card">
            <span class="sf-icon">🔔</span>
            <h3>Discord Integration</h3>
            <p>Connect your Discord account, show game status, and invite friends directly.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section">
      <div class="container" style="text-align:center">
        <h2 class="section-title">Development Roadmap</h2>
        <div class="timeline">
          <div class="tl-item tl-done">
            <div class="tl-dot"></div>
            <div class="tl-body">
              <div class="tl-label">✓ Complete</div>
              <div class="tl-title">Core Games Engine</div>
              <p>All 17 base games implemented with offline AI.</p>
            </div>
          </div>
          <div class="tl-item tl-active">
            <div class="tl-dot"></div>
            <div class="tl-body">
              <div class="tl-label">In Progress</div>
              <div class="tl-title">Online Multiplayer &amp; Matchmaking</div>
              <p>Real-time servers, ranked matchmaking, private tables.</p>
            </div>
          </div>
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-body">
              <div class="tl-label">Coming Next</div>
              <div class="tl-title">Social Features &amp; Google Play Launch</div>
              <p>Voice chat, Discord, leaderboards, achievements — then Play Store submission.</p>
            </div>
          </div>
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-body">
              <div class="tl-label">Post-Launch</div>
              <div class="tl-title">16 Coming-Soon Games</div>
              <p>War, Canasta, Koi-Koi, Seep, Whist and many more — premium subscribers first.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="store-footer-cta">
      <div class="container" style="text-align:center">
        <p>In the meantime, explore the full game catalog and pricing.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.25rem">
          <a href="/games"   class="btn btn-primary">Browse Games</a>
          <a href="/pricing" class="btn btn-secondary">View Pricing</a>
          <a href="/ios"     class="btn btn-secondary">App Store page →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    (e.target as HTMLFormElement).style.display = 'none';
    document.getElementById('notify-confirm')!.hidden = false;
  }
</script>

<style>
  .store-page--android { --platform-color: #3ddc84; --platform-dark: #1ea85b; }

  .store-hero {
    background: linear-gradient(160deg, var(--bg-deep) 0%, #091a0f 100%);
    padding: 5rem 0 4rem; border-bottom: 1px solid var(--border);
  }
  .back-link { font-size:.82rem; color:var(--text-muted); transition:color var(--transition); display:inline-block; margin-bottom:2.5rem; }
  .back-link:hover { color:var(--gold-light); }

  .store-hero-inner { max-width: 680px; }
  .platform-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(61,220,132,.10); border: 1px solid rgba(61,220,132,.3);
    border-radius: var(--radius-full); padding: .4rem 1rem;
    font-size: .78rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--platform-color); margin-bottom: 1.25rem;
  }
  .platform-icon { font-size: 1rem; }
  .store-title {
    font-size: clamp(2.5rem,6vw,4.5rem); font-weight: 900;
    line-height: 1.1; margin-bottom: 1rem; color: var(--text-primary);
  }
  .platform-accent { color: var(--platform-color); }
  .store-subtitle { font-size:1.05rem; color:var(--text-muted); line-height:1.75; margin-bottom:1.5rem; max-width:580px; }
  .store-meta { display:flex; gap:.5rem; flex-wrap:wrap; }
  .meta-chip { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-full); padding:.3rem .85rem; font-size:.78rem; color:var(--text-secondary); }

  .notify-section { background:var(--bg-secondary); border-bottom:1px solid var(--border); padding:3rem 0; }
  .notify-inner { display:flex; align-items:center; gap:2.5rem; flex-wrap:wrap; }
  .notify-copy h2 { font-size:1.3rem; margin-bottom:.4rem; }
  .notify-copy p  { font-size:.9rem; color:var(--text-muted); }
  .notify-form { display:flex; gap:.5rem; flex-wrap:wrap; flex:1; min-width:280px; }
  .notify-input {
    flex:1; min-width:200px; padding:.7rem 1rem;
    background:var(--bg-card); border:1px solid var(--border);
    border-radius:var(--radius-md); color:var(--text-primary);
    font-family:'Inter',sans-serif; font-size:.9rem;
  }
  .notify-input:focus { outline:none; border-color:var(--platform-color); }
  .notify-btn { background:var(--platform-dark) !important; color:#fff !important; }
  .notify-fine { font-size:.82rem; color:#7acc7a; margin-top:.5rem; width:100%; }

  .store-features { padding:4rem 0; }
  .sf-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1rem; }
  .sf-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.5rem; transition:all var(--transition); }
  .sf-card:hover { border-color:rgba(61,220,132,.4); transform:translateY(-2px); }
  .sf-icon { font-size:2rem; display:block; margin-bottom:.75rem; }
  .sf-card h3 { font-size:1rem; font-weight:700; font-family:'Inter',sans-serif; margin-bottom:.4rem; color:var(--text-primary); }
  .sf-card p  { font-size:.85rem; color:var(--text-muted); line-height:1.6; }

  .timeline-section { background:var(--bg-secondary); border-top:1px solid var(--border); padding:4rem 0; }
  .timeline { display:flex; flex-direction:column; gap:0; max-width:600px; margin:2rem auto 0; }
  .tl-item { display:flex; gap:1.25rem; position:relative; padding-bottom:2rem; }
  .tl-item:last-child { padding-bottom:0; }
  .tl-item::before { content:''; position:absolute; left:10px; top:22px; bottom:0; width:2px; background:var(--border); }
  .tl-item:last-child::before { display:none; }
  .tl-dot { width:22px; height:22px; border-radius:50%; border:2px solid var(--border); background:var(--bg-card); flex-shrink:0; margin-top:2px; }
  .tl-done .tl-dot   { background:var(--gold); border-color:var(--gold); }
  .tl-active .tl-dot { background:var(--platform-color); border-color:var(--platform-color); box-shadow:0 0 10px rgba(61,220,132,.4); }
  .tl-body { flex:1; }
  .tl-label { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--text-dim); margin-bottom:.2rem; }
  .tl-done .tl-label   { color:var(--gold); }
  .tl-active .tl-label { color:var(--platform-color); }
  .tl-title { font-size:.95rem; font-weight:700; font-family:'Inter',sans-serif; color:var(--text-primary); margin-bottom:.25rem; }
  .tl-body p { font-size:.83rem; color:var(--text-muted); line-height:1.55; }

  .store-footer-cta { background:var(--bg-deep); border-top:1px solid var(--border); padding:3rem 0; }
  .store-footer-cta p { font-size:1rem; color:var(--text-muted); }
</style>
